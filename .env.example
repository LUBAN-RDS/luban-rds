# Luban-RDS Docker Compose Environment Configuration
# Copy this file to .env and modify as needed

# Server Configuration
LUBAN_RDS_PORT=9736
LUBAN_RDS_BIND=0.0.0.0
LUBAN_RDS_DATABASES=16

# Persistence Configuration
# Options: rdb, aof, mixed, none
LUBAN_RDS_PERSIST_MODE=rdb

# Memory Configuration
# Max memory in bytes (0 = unlimited)
LUBAN_RDS_MAXMEMORY=0

# Security
# Set a strong password for production
LUBAN_RDS_REQUIREPASS=

# JVM Options
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:MaxGCPauseMillis=50
